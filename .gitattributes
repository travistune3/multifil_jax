# Normalize line endings to LF for all text files
* text=auto eol=lf

# Python
*.py text eol=lf

# Config / data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.md text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.npz binary
*.npy binary
